# Local Postgres via Docker Compose (infra/docker/docker-compose.yml).
# Copy this file to .env and adjust as needed. .env is gitignored.
#
# Host port 5434 — not 5432 — because Windows machines often have a
# system PostgreSQL service bound to 5432, and Docker Desktop's WSL
# relay can hold 5433. The container listens internally on 5432 but
# is mapped to host 5434.
DATABASE_URL="postgresql://vendoora:vendoora_dev_password@localhost:5434/vendoora_dev?schema=public"

# Test database — same host/port, different database name. Used by `pnpm -F @vendoora/db test`.
DATABASE_URL_TEST="postgresql://vendoora:vendoora_dev_password@localhost:5434/vendoora_test?schema=public"
