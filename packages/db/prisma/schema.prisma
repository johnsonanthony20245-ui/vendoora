  PENDING_SELLER
  ESCALATED
  RESOLVED_FAVOR_BUYER
  RESOLVED_FAVOR_SELLER
  RESOLVED_PARTIAL
  RESOLVED_INSURANCE
  CLOSED
  WITHDRAWN
}

enum DisputeResolution {
  FULL_REFUND_TO_BUYER
