// ============================================================================
// Trust Cases (Engineering_Spec §4.14 — May 2026 addition)
// Polymorphic subject (7 types). Auto-creation engine + assignment logic
// lives in packages/domain/src/trust/ (P6 Admin/RBAC).
// ============================================================================

model TrustCase {
  id              String      @id @default(cuid())
  case_number     String      @unique

  subject_type    TrustSubjectType
  subject_id      String

  title           String
  summary         String
  status          TrustCaseStatus  @default(NEW)
  severity        TrustSeverity

  assigned_to_user_id  String?
  assigned_at          DateTime?

  due_date            DateTime

  resolved_at         DateTime?
  resolution_summary  String?
  resolution_action   TrustResolution?

  auto_created            Boolean     @default(false)
  auto_creation_signal    String?

  created_at      DateTime    @default(now())
  created_by_user_id String?
  updated_at      DateTime    @updatedAt

  parent_case_id  String?

  assigned_to     User?       @relation("TrustCaseAssignee", fields: [assigned_to_user_id], references: [id])
  created_by      User?       @relation("TrustCaseCreator", fields: [created_by_user_id], references: [id])
  parent_case     TrustCase?  @relation("follow_up_parent", fields: [parent_case_id], references: [id])
  follow_ups      TrustCase[] @relation("follow_up_parent")
  notes           TrustCaseNote[]
  actions         TrustCaseAction[]

  @@index([subject_type, subject_id])
  @@index([status, due_date])
  @@index([assigned_to_user_id, status])
  @@index([severity, due_date])
  @@index([created_at])
  @@map("trust_cases")
}

enum TrustSubjectType {
  SELLER
  DRIVER
  PRODUCT
  ORDER
  DISPUTE
  KYC
  USER
}

enum TrustCaseStatus {
  NEW
  HEALTHY
