{
  "name": "@vendoora/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "prisma": "prisma",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:reset": "prisma migrate reset --force --skip-seed",
    "generate": "prisma generate",
    "seed": "prisma db seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "echo \"no lint yet\" && exit 0",
    "build": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@vendoora/config": "workspace:*",
    "@types/node": "^22.9.0",
    "dotenv": "^16.4.5",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "vite-tsconfig-paths": "^5.1.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
